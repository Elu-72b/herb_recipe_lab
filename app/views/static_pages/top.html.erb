<%# 画面全体を中央寄せにするコンテナ %>
<div class="min-h-screen bg-gradient-to-br flex flex-col items-center justify-center p-4 space-y-6 w-full">
  <%# 1. ヘッダーエリア (タイトルを表示) %>
  <header class="w-full py-8 flex justify-center">
    <div class="bg-herb-green-100 px-12 py-4 rounded-full shadow-sm border border-herb-green-600/20">
      <h1 class="text-2xl md:text-3xl text-herb-green-700 font-medium tracking-wide">
        Herb Recipe Lab
      </h1>
    </div>
  </header>

  <%# 2. メインコンテンツエリア (上下左右の中央に配置) %>
  <main class="flex-grow flex flex-col items-center justify-center px-4 pb-20">
    
    <%# ページ見出し %>
    <h2 class="text-4xl md:text-5xl font-light text-herb-green-700 mb-10 tracking-widest">
      ログイン
    </h2>

    <%# 3. ログインカード %>
    <div class="w-full max-w-sm bg-white rounded-2xl shadow-sm border border-herb-green-100 p-8 md:p-10">
      <form class="space-y-8">
        
        <div>
          <label class="block text-lg text-herb-green-700 mb-3 ml-1">メールアドレス</label>
          <input type="email" placeholder="Value" class="text-lg">
        </div>

        <div>
          <label class="block text-lg text-herb-green-700 mb-3 ml-1">パスワード</label>
          <input type="password" placeholder="Value" class="text-lg">
        </div>

        <div class="pt-2">
          <button type="submit" class="w-full py-4 bg-herb-green-600 text-white text-xl font-medium rounded-xl hover:bg-herb-green-700 transition-colors shadow-sm active:transform active:scale-[0.99]">
            ログイン
          </button>
        </div>

        <div class="pt-2">
          <button type="submit" class="w-full py-4 bg-herb-green-600 text-white text-xl font-medium rounded-xl hover:bg-herb-green-700 transition-colors shadow-sm active:transform active:scale-[0.99]">
            新規作成
          </button>
        </div>

        <div class="text-center pt-2">
          <a href="#" class="text-herb-green-700 border-b border-herb-green-700 pb-0.5 hover:opacity-70 transition-opacity">
            パスワードをお忘れの方はこちら
          </a>
        </div>

      </form>
    </div>
  </main>
</div>