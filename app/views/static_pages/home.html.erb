<%# 画面全体を中央寄せにするコンテナ %>
<div class="min-h-screen bg-gradient-to-br flex flex-col items-center justify-center p-4 space-y-6 w-full">
  <%# ヘッダーエリア (タイトルを表示) %>
  <%= render 'shared/header' %>

<div class="max-w-sm bg-white rounded-2xl shadow-sm border border-herb-green-100 p-8 md:p-10">
    <div class="bg-herb-green-100 px-8 py-2 rounded-full shadow-sm border border-herb-green-600/20">
      <h2 class="display: justify-content: center flex text-2xl md:text-2xl text-herb-green-700 font-medium tracking-wide">
        ブレンド研究一覧
      </h2>
    </div>
    <br>
    <div class="flex-grow flex flex-col items-center justify-center border-2 border-dashed border-herb-green-50 rounded-2xl py-12 mb-6 bg-herb-green-50/30">
        <p class="text-herb-green-300 text-sm">研究データがまだありません</p>
        <p class="text-herb-green-200 text-xs">最初の一杯を記録しましょう</p>
    </div>
    <br>
    <div class="pt-2" w-full>
        <button type="submit" class="w-full py-4 bg-herb-green-600 text-white text-l font-medium rounded-xl hover:bg-herb-green-700 transition-colors shadow-sm active:transform active:scale-[0.99]">
        ブレンド研究記録を作成する
        </button>
    </div>
</div>
<div class="text-center pt-8">
  <%= link_to "ログアウト", destroy_user_session_path, data: { turbo_method: :delete }, 
      class: "text-herb-green-500 text-sm hover:text-herb-green-700 transition-colors border-b border-herb-green-200" %>
</div>
<%= render 'shared/footer' %>