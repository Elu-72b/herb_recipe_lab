<div class="min-h-screen bg-gradient-to-br flex flex-col items-center justify-center p-4 space-y-6 w-full">

  <%# 1. ヘッダーエリア（共通） %>
<%= render 'shared/header' %>

  <%# 2. メインコンテンツエリア %>
  <main class="flex-grow flex flex-col items-center justify-center px-4 pb-20">

    <%# ページ見出し %>
    <h2 class="text-4xl md:text-5xl font-light text-herb-green-700 mb-10 tracking-widest">
      新規登録
    </h2>

    <%# 3. 登録カード %>
    <div class="w-full max-w-sm bg-white rounded-2xl shadow-sm border border-herb-green-100 p-8 md:p-10">
      <form class="space-y-6">

        <%# ユーザー名（任意で追加） %>
        <div>
          <label class="block text-lg text-herb-green-700 mb-2 ml-1">ユーザー名</label>
          <input type="text" placeholder="Herb Lover" class="text-lg">
        </div>

        <%# メールアドレス %>
        <div>
          <label class="block text-lg text-herb-green-700 mb-2 ml-1">メールアドレス</label>
          <input type="email" placeholder="example@mail.com" class="text-lg">
        </div>

        <%# パスワード %>
        <div>
          <label class="block text-lg text-herb-green-700 mb-2 ml-1">パスワード</label>
          <input type="password" placeholder="6文字以上" class="text-lg">
        </div>

        <%# パスワード（確認用） %>
        <div>
          <label class="block text-lg text-herb-green-700 mb-2 ml-1">パスワード（確認用）</label>
          <input type="password" placeholder="もう一度入力してください" class="text-lg">
        </div>

        <%# 登録ボタン %>
        <div class="pt-4">
          <button type="submit" class="btn-primary-lg w-full justify-center">
            アカウントを作成
          </button>
        </div>

        <%# ログインへの誘導リンク %>
        <div class="text-center pt-2">
          <p class="text-herb-green-600 text-sm">既にアカウントをお持ちですか？</p>
          <%= link_to "ログインはこちら", root_path,
              class: "text-herb-green-700 font-bold border-b border-herb-green-700 pb-0.5 hover:opacity-70 transition-opacity inline-block mt-1" %>
        </div>

      </form>
    </div>
  </main>
</div>
