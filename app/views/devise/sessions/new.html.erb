<%# app/views/devise/sessions/new.html.erb %>
<div class="min-h-screen bg-gradient-to-br flex flex-col items-center justify-center p-4 space-y-6 w-full">
  <main class="w-full max-w-sm bg-white rounded-2xl shadow-sm border border-herb-green-100 p-8 md:p-10">
    <h2 class="text-3xl font-light text-herb-green-700 mb-8 text-center tracking-widest">ログイン</h2>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-6" }) do |f| %>
      <div>
        <%= f.label :email, "メールアドレス", class: "block text-lg text-herb-green-700 mb-2 ml-1" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full p-3 border border-herb-green-100 rounded-xl focus:ring-2 focus:ring-herb-green-600 outline-none" %>
      </div>

      <div>
        <%= f.label :password, "パスワード", class: "block text-lg text-herb-green-700 mb-2 ml-1" %>
        <%= f.password_field :password, autocomplete: "current-password", class: "w-full p-3 border border-herb-green-100 rounded-xl focus:ring-2 focus:ring-herb-green-600 outline-none" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="flex items-center ml-1">
          <%= f.check_box :remember_me, class: "rounded text-herb-green-600 focus:ring-herb-green-500" %>
          <%= f.label :remember_me, "ログイン状態を保持する", class: "ml-2 text-sm text-herb-green-600" %>
        </div>
      <% end %>

      <div class="pt-4">
        <%= f.submit "ログイン", class: "w-full py-4 bg-herb-green-600 text-white text-xl font-medium rounded-xl hover:bg-herb-green-700 transition-colors cursor-pointer" %>
      </div>
    <% end %>

    <div class="text-center pt-4">
      <%= render "devise/shared/links" %>
    </div>
  </main>
</div>