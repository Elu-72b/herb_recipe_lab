<%# ログインフォーム %>
<div class="w-full max-w-sm bg-white rounded-2xl shadow-sm border border-herb-green-100 p-8 md:p-10">
    <h2 class="text-4xl md:text-5xl font-light text-herb-green-700 mb-10 tracking-widest">
    ログイン
    </h2>
    <div class="flex-grow flex flex-col items-center justify-center px-4 pb-20">
        <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "w-full space-y-8" }) do |f| %>
            <div>
                <%= f.label :email, "メールアドレス", class: "block text-lg text-herb-green-700 mb-3 ml-1" %>
                <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "example@mail.com", class: "w-full p-3 border border-herb-green-100 rounded-xl focus:ring-2 focus:ring-herb-green-600 focus:border-transparent outline-none text-lg" %>
            </div>
            <div>
                <%= f.label :password, "パスワード", class: "block text-lg text-herb-green-700 mb-3 ml-1" %>
                <%= f.password_field :password, autocomplete: "current-password", placeholder: "Password", class: "w-full p-3 border border-herb-green-100 rounded-xl focus:ring-2 focus:ring-herb-green-600 focus:border-transparent outline-none text-lg" %>
            </div>

            <div class="pt-2">
                <%= f.submit "ログイン", class: "btn-primary-lg w-full justify-center" %>
            </div>
            <div class="pt-2">
                <%= link_to "新規作成", signup_path, class: "btn-primary-lg w-full justify-center" %>
            </div>
        <% end %>
    </div>

  <%# <div class="text-center pt-2"> %>
    <%# <%= link_to "パスワードをお忘れの方はこちら", new_password_path(resource_name), class: "text-herb-green-700 border-b border-herb-green-700 pb-0.5 hover:opacity-70 transition-opacity" %>
  <%# </div> %>
</div>