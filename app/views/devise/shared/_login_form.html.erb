    <%# ログインフォーム %>
<div class="w-full max-w-sm bg-white rounded-2xl shadow-sm border border-herb-green-100 p-8 md:p-10">
    <%# ページ見出し %>
    <h2 class="text-4xl md:text-5xl font-light text-herb-green-700 mb-10 tracking-widest">
    ログイン
    </h2>

    <main class="flex-grow flex flex-col items-center justify-center px-4 pb-20">

        <%# ログインカード %>
        <div class="space-y-8">
            <div>
                <label class="block text-lg text-herb-green-700 mb-3 ml-1">メールアドレス</label>
                <input type="email" placeholder="Value" class="text-lg">
            </div>

            <div>
                <label class="block text-lg text-herb-green-700 mb-3 ml-1">パスワード</label>
                <input type="password" placeholder="Value" class="text-lg">
            </div>

            <div class="pt-2">
                <button type="submit" class="block w-full py-4 bg-herb-green-600 text-white text-xl font-medium rounded-xl hover:bg-herb-green-700 transition-colors shadow-sm active:transform active:scale-[0.99]">
                    ログイン
                </button>
            </div>
            <div class="pt-2">
                <%= link_to "新規作成", signup_path, class: "block w-full text-center py-4 bg-herb-green-600 text-white text-xl font-medium rounded-xl hover:bg-herb-green-700 transition-colors shadow-sm active:transform active:scale-[0.99]" %>
            </div>
        </div>
    </main>

  <div class="text-center pt-2">
    <a href="#" class="text-herb-green-700 border-b border-herb-green-700 pb-0.5 hover:opacity-70 transition-opacity">
        パスワードをお忘れの方はこちら
    </a>
  </div>
</div>