<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Myapp" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <div class="fixed top-4 right-4 z-50 space-y-2">
      <% if notice %>
        <div class="bg-herb-green-100 border border-herb-green-600 text-herb-green-700 px-6 py-3 rounded-xl shadow-lg">
          <%= notice %>
        </div>
      <% end %>
      <% if alert %>
        <div class="bg-red-100 border border-red-600 text-red-700 px-6 py-3 rounded-xl shadow-lg">
          <%= alert %>
        </div>
      <% end %>
    </div>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body>
    <main class="container mx-auto mt-28 px-5 flex">
      <%= yield %>
    </main>
  </body>
  <footer class="py-8 text-center text-sm text-herb-green-700/60">
      <p>&copy; 2026 Herb Recipe Lab</p>
  </footer>
</html>
