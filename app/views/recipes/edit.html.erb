<%# app/views/recipes/edit.html.erb %>
<div class="min-h-screen bg-gradient-to-br from-herb-green-50 flex flex-col items-center p-3 w-full">

  <div class="max-w-lg w-full bg-white rounded-2xl shadow-sm border border-herb-green-100 p-6 md:p-10 my-8">

    <%# タイトル %>
    <div class="flex justify-center mb-6">
      <div class="bg-herb-green-100 px-6 py-2 rounded-full shadow-sm border border-herb-green-600/20">
        <h2 class="text-xl text-herb-green-700 font-medium tracking-wide">
          STEP 1｜ブレンドを修正する
        </h2>
      </div>
    </div>

    <%# バリデーションエラー表示 %>
    <% if @recipe.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded-xl p-4 mb-6">
        <p class="text-red-600 text-sm font-medium mb-1">入力内容を確認してください</p>
        <ul class="text-red-500 text-sm space-y-1">
          <% @recipe.errors.full_messages.each do |msg| %>
            <li>・<%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: @recipe, class: "space-y-2" do |f| %>

      <%# レシピ名 %>
      <div>
        <%= f.label :title, "レシピ名", class: "form-label" %>
        <%= f.text_field :title,
              placeholder: "例）夜のリラックスブレンド",
              class: "w-full border border-herb-green-200 rounded-xl px-4 py-2 text-sm
                      focus:outline-none focus:ring-2 focus:ring-herb-green-400" %>
      </div>

      <%# 作成日 %>
      <div>
        <%= f.label :brewed_at, "作成日", class: "form-label" %>
        <%= f.date_field :brewed_at,
              class: "w-full border border-herb-green-200 rounded-xl px-4 py-2 text-sm
                      focus:outline-none focus:ring-2 focus:ring-herb-green-400 mb-1" %>
      </div>

      <%# 抽出量 %>
      <div>
        <%= f.label :amount, "抽出量（ml）", class: "form-label" %>
        <div class="flex items-center gap-2">
          <%= f.number_field :amount,
                min: 1,
                placeholder: "200",
                class: "w-full border border-herb-green-200 rounded-xl px-4 py-2 text-sm
                        focus:outline-none focus:ring-2 focus:ring-herb-green-400" %>
          <span class="text-sm text-gray-400 whitespace-nowrap">ml</span>
        </div>
      </div>

      <%# ハーブ配合 %>
      <div>
        <p class="form-label">ハーブ配合</p>
        <div class="space-y-3" id="recipe-herbs-fields">
          <%= f.fields_for :recipe_herbs do |herb_f| %>
            <% is_custom = herb_f.object.herb_id.nil? && herb_f.object.custom_herb_name.present? %>
            <div class="flex gap-1 items-center recipe-herb-row">
              <%= herb_f.select :herb_id,
                    options_from_collection_for_select(@herbs, :id, :name, is_custom ? nil : herb_f.object.herb_id) +
                    options_for_select([["その他", "other"]], is_custom ? "other" : nil),
                    { include_blank: "ハーブを選択" },
                    class: "flex-1 border border-herb-green-200 rounded-xl px-4 py-2 text-xs focus:outline-none focus:ring-2 focus:ring-herb-green-400",
                    onchange: "toggleCustomHerb(this)" %>

              <%= herb_f.text_field :custom_herb_name,
                    placeholder: "ハーブ名を入力",
                    class: "flex-1 border border-herb-green-200 rounded-xl px-4 py-2 text-xs focus:outline-none focus:ring-2 focus:ring-herb-green-400 custom-herb-name",
                    style: is_custom ? "" : "display:none" %>

              <%= herb_f.number_field :quantity, step: 0.1, min: 0, placeholder: "量",
                    class: "w-14 border border-herb-green-200 rounded-xl px-2 py-2 text-xs focus:outline-none focus:ring-2 focus:ring-herb-green-400" %>

              <%= herb_f.select :unit, [["g", "g"], ["小さじ", "teaspoon"], ["枚", "piece"], ["個", "individual"]], {},
                    class: "w-18 border border-herb-green-200 rounded-xl px-2 py-2 text-xs focus:outline-none focus:ring-2 focus:ring-herb-green-400" %>

              <%= herb_f.hidden_field :id %>
              <%= herb_f.check_box :_destroy, class: "hidden" %>
              <button type="button" onclick="this.closest('.recipe-herb-row').remove()"
                class="text-red-400 hover:text-red-600 text-lg font-bold px-1 leading-none">
                ×
              </button>
            </div>
          <% end %>
        </div>

        <%# ハーブ追加ボタン %>
        <button type="button" id="add-herb-btn"
          class="mt-3 text-herb-green-600 text-sm border border-herb-green-300 rounded-xl
                 px-4 py-2 hover:bg-herb-green-50 transition-colors w-full">
          ＋ ハーブを追加する
        </button>
      </div>

      <%# 淹れる前のメモ %>
      <div>
        <%= f.label :memo, "淹れる前のメモ（任意）",
              class: "form-label" %>
        <%= f.text_area :memo,
              rows: 3,
              placeholder: "例）鎮静効果のあるハーブを中心に配合",
              class: "w-full border border-herb-green-200 rounded-xl px-4 py-2 text-sm
                      focus:outline-none focus:ring-2 focus:ring-herb-green-400 resize-none" %>
      </div>

      <%# 更新・戻るボタン %>
      <div class="pt-2 space-y-3 flex flex-col items-center">
        <%= f.submit "記録を更新する", class: "btn-primary-lg" %>
        <%= link_to "一覧に戻る", home_path, class: "btn-list-back" %>
      </div>

    <% end %>

  </div>

  <%= render 'shared/footer' %>
</div>

<%# ハーブ行を動的に追加するJavaScript %>
<script data-turbo-track="reload">
  function toggleCustomHerb(select) {
    const row = select.closest(".recipe-herb-row");
    const customInput = row.querySelector(".custom-herb-name");
    if (select.value === "other") {
      customInput.style.display = "";
      customInput.removeAttribute("disabled");
    } else {
      customInput.style.display = "none";
      customInput.value = "";
      customInput.setAttribute("disabled", "disabled");
    }
  }

  document.addEventListener("turbo:load", function () {
    const addBtn = document.getElementById("add-herb-btn");
    if (!addBtn) return;
    if (addBtn.dataset.listener === "true") return;

    const herbOptions = `
      <option value="">ハーブを選択</option>
      <% @herbs.each do |herb| %>
        <option value="<%= herb.id %>"><%= herb.name %></option>
      <% end %>
      <option value="other">その他</option>
    `;

    addBtn.addEventListener("click", function () {
      const container = document.getElementById("recipe-herbs-fields");
      const herbIndex = container.querySelectorAll(".recipe-herb-row").length;

      const row = document.createElement("div");
      row.className = "flex gap-1 items-center recipe-herb-row";
      row.innerHTML = `
        <select name="recipe[recipe_herbs_attributes][${herbIndex}][herb_id]"
          class="flex-1 border border-herb-green-200 rounded-xl px-4 py-2 text-xs focus:outline-none focus:ring-2 focus:ring-herb-green-400"
          onchange="toggleCustomHerb(this)">
          ${herbOptions}
        </select>

        <input type="text"
          name="recipe[recipe_herbs_attributes][${herbIndex}][custom_herb_name]"
          placeholder="ハーブ名を入力"
          class="flex-1 border border-herb-green-200 rounded-xl px-4 py-2 text-xs focus:outline-none focus:ring-2 focus:ring-herb-green-400 custom-herb-name"
          style="display:none" disabled />

        <input type="number" step="0.1" min="0"
          name="recipe[recipe_herbs_attributes][${herbIndex}][quantity]"
          placeholder="量"
          class="w-14 border border-herb-green-200 rounded-xl px-2 py-2 text-xs focus:outline-none focus:ring-2 focus:ring-herb-green-400" />

        <select name="recipe[recipe_herbs_attributes][${herbIndex}][unit]"
          class="w-18 border border-herb-green-200 rounded-xl px-2 py-2 text-xs focus:outline-none focus:ring-2 focus:ring-herb-green-400">
          <option value="teaspoon">小さじ</option>
          <option value="tablespoon">大さじ</option>
          <option value="g">g</option>
          <option value="piece">枚</option>
          <option value="individual">個</option>
        </select>

        <button type="button"
          onclick="this.closest('.recipe-herb-row').remove()"
          class="text-red-400 hover:text-red-600 text-lg font-bold px-1 leading-none">
          ×
        </button>
      `;
      container.appendChild(row);
    });

    addBtn.dataset.listener = "true";
  });
</script>
