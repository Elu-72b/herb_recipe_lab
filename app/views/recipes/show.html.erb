<%# app/views/recipes/show.html.erb %>
<div class="min-h-screen bg-gradient-to-br from-herb-green-50 flex flex-col items-center p-4 w-full">

  <div class="max-w-2xl w-full space-y-3">
    <%# レシピの基本情報カード %>
    <div class="bg-white rounded-2xl shadow-sm border border-herb-green-100 p-6 md:p-8">
      <%# レシピ名・作成日・投稿者 %>
      <div class="flex justify-between items-start mb-4">
        <div>
          <h1 class="text-2xl font-bold text-herb-green-800"><%= @recipe.title %></h1>
          <p class="text-xs text-gray-400 mt-1">
            作成日: <%= @recipe.brewed_at %> | 投稿者: <%= @recipe.user.name %>
          </p>
        </div>
        <% if @recipe.user == current_user %>
          <div class="flex gap-2">
            <%= link_to "レシピ編集", edit_recipe_path(@recipe), class: "text-xs bg-herb-green-50 text-herb-green-600 px-3 py-1 rounded-full border border-herb-green-200 hover:bg-herb-green-100" %>
            <%= link_to "削除", recipe_path(@recipe), data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" }, class: "text-xs bg-red-50 text-red-600 px-3 py-1 rounded-full border border-red-200 hover:bg-red-100" %>
          </div>
        <% end %>
      </div>

    <%# ハーブ配合 & ブレンドの特徴 を横並び %>
    <% herbs_in_recipe = @recipe.recipe_herbs.map(&:herb).compact %>
      <%# ハーブのタグ情報を取得、重複しないようにuniq %>
      <% all_flavor_tags     = herbs_in_recipe.flat_map(&:flavor_tags).uniq %>
      <% all_functional_tags = herbs_in_recipe.flat_map(&:functional_tags).uniq %>
      <% all_caution_tags    = herbs_in_recipe.flat_map(&:caution_tags).uniq %>
      <% has_tags = all_flavor_tags.any? || all_functional_tags.any? || all_caution_tags.any? %>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <%= render 'recipes/recipe_summary', recipe: @recipe %>
          <div class="mb-6 p-4 bg-herb-green-50 rounded-xl space-y-3">
          <h2 class="text-sm font-bold text-herb-green-700 mb-3 border-b border-herb-green-100 pb-2">このブレンドの特徴</h2>
            <% if all_flavor_tags.any? %>
              <div class="mb-3">
                <p class="text-xs text-herb-green-700/50 mb-1">風味</p>
                <div class="flex flex-wrap gap-1">
                  <% all_flavor_tags.each do |tag| %>
                    <span class="tag-herb"><%= tag.name %></span>
                  <% end %>
                </div>
              </div>
            <% end %>
            <% if all_functional_tags.any? %>
              <div class="mb-3">
                <p class="text-xs text-herb-green-700/50 mb-1">効能</p>
                <div class="flex flex-wrap gap-1">
                  <% all_functional_tags.each do |tag| %>
                    <span class="tag-benefit"><%= tag.name %></span>
                  <% end %>
                </div>
              </div>
            <% end %>
            <% if all_caution_tags.any? %>
              <div class="mb-3">
                <p class="text-xs text-herb-green-700/50 mb-1">禁忌</p>
                <div class="flex flex-wrap gap-1">
                  <% all_caution_tags.each do |tag| %>
                    <span class="bg-red-100 text-red-700 text-xs px-2 py-0.5 rounded-full">
                      ⚠ <%= tag.name %>
                    </span>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
  </div>
    <%# 感想カード: DrinkingLog 情報 %>
    <div class="bg-white rounded-2xl shadow-sm border border-herb-green-100 p-6 md:p-8">
      <div class="flex justify-between items-center mb-6">
        <div class="flex items-center gap-3">
          <h2 class="text-xl font-bold text-herb-green-800">研究結果の感想</h2>
          <% if @recipe.drinking_log %>
            <div class="bg-yellow-100 text-yellow-700 px-3 py-1 rounded-full text-md font-bold">
              ★ <%= @recipe.drinking_log.rating %> / 5
            </div>
          <% end %>
        </div>
        <% if @recipe.drinking_log && @recipe.user == current_user %>
          <%= link_to "感想を編集", edit_recipe_drinking_log_path(@recipe, @recipe.drinking_log),
                class: "text-xs bg-herb-green-50 text-herb-green-600 px-3 py-1 rounded-full border border-herb-green-200 hover:bg-herb-green-100" %>
        <% end %>
      </div>

      <% if @recipe.drinking_log %>
        <div class="space-y-6">
          <%# 味のパラメータ表示 %>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
            <% DrinkingLog::FLAVOR_MAPPING.each do |ja_name, column| %>
              <% value = @recipe.drinking_log.send(column).to_i %>
              <div class="flex flex-col items-center p-2 border-herb-green-100 rounded-lg border border-herb-green-100">
                <div class="flex justify-between w-full px-1 mb-1">
                  <span class="text-[12px] text-gray-500"><%= ja_name %></span>
                  <span class="text-[12px] font-bold text-herb-green-600"><%= value %></span>
                </div>
                <div class="flex gap-0.5">
                  <% 5.times do |i| %>
                    <div class="w-4 h-4 rounded-sm <%= i < value ? 'bg-herb-green-600' : 'bg-gray-200' %>"></div>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>

          <%# 感想テキスト %>
          <%if @recipe.drinking_log.impression.present? %>
            <h2 class="text-sm font-bold text-herb-green-700 mb-1 border-herb-green-100 pb-2">感想</h2>
            <div class="bg-herb-green-50/30 rounded-xl p-4 border border-herb-green-100">
              <p class="text-sm text-herb-green-900 whitespace-pre-wrap"><%= @recipe.drinking_log.impression %></p>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="text-center py-8">
          <p class="text-sm text-gray-400 mb-4">まだ感想が記録されていません</p>
          <% if @recipe.user == current_user %>
            <%= link_to "感想を入力する", new_recipe_drinking_log_path(@recipe),
                  class: "btn-primary-lg w-full justify-center" %>
          <% end %>
        </div>
      <% end %>
    </div>

    <%# 戻るリンク %>
    <div class="text-center">
      <%= link_to "← 一覧に戻る", home_path,
            class: "inline-block border border-herb-green-600 text-herb-green-600 rounded-full px-5 py-2 text-sm hover:bg-herb-green-50 transition" %>
    </div>
  </div>

  <%= render 'shared/footer' %>
</div>
