<%# app/views/recipes/show.html.erb %>
<div class="min-h-screen bg-gradient-to-br from-herb-green-50 to-white flex flex-col items-center p-4 w-full">
  <%= render 'shared/header' %>

  <div class="max-w-2xl w-full space-y-6 my-8">
    <%# メインカード: レシピ基本情報 %>
    <div class="bg-white rounded-2xl shadow-sm border border-herb-green-100 p-6 md:p-8">
      <div class="flex justify-between items-start mb-4">
        <div>
          <h1 class="text-2xl font-bold text-herb-green-800"><%= @recipe.title %></h1>
          <p class="text-xs text-gray-400 mt-1">
            作成日: <%= @recipe.brewed_at %> | 投稿者: <%= @recipe.user.name %>
          </p>
        </div>
        <% if @recipe.user == current_user %>
          <div class="flex gap-2">
            <%= link_to "編集", edit_recipe_path(@recipe), class: "text-xs bg-herb-green-50 text-herb-green-600 px-3 py-1 rounded-full border border-herb-green-200 hover:bg-herb-green-100" %>
            <%= link_to "削除", recipe_path(@recipe), data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" }, class: "text-xs bg-red-50 text-red-600 px-3 py-1 rounded-full border border-red-200 hover:bg-red-100" %>
          </div>
        <% end %>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-6">
        <%# 左側: ハーブ配合 %>
        <div class="bg-herb-green-50/50 rounded-xl p-4">
          <h3 class="text-sm font-bold text-herb-green-700 mb-3 border-b border-herb-green-200 pb-1">🌿 ハーブ配合</h3>
          <ul class="space-y-2">
            <% @recipe.recipe_herbs.each do |rh| %>
              <li class="flex justify-between text-sm">
                <span class="text-herb-green-800"><%= rh.herb.name %></span>
                <span class="font-medium text-herb-green-600">
                  <% unit_labels = { "g" => "g", "teaspoon" => "小さじ", "piece" => "枚", "individual" => "個" } %>
                  <%= rh.quantity %> <%= unit_labels[rh.unit] %>
                </span>
              </li>
            <% end %>
          </ul>
          <div class="mt-4 pt-3 border-t border-herb-green-100 flex justify-between text-xs text-gray-500">
            <span>抽出量</span>
            <span><%= @recipe.amount %> ml</span>
          </div>
        </div>

        <%# 右側: 淹れる前のメモ %>
        <div>
          <h3 class="text-sm font-bold text-herb-green-700 mb-3 border-b border-herb-green-200 pb-1">📝 研究メモ</h3>
          <p class="text-sm text-gray-600 leading-relaxed">
            <%= @recipe.memo.presence || "（メモはありません）" %>
          </p>
        </div>
      </div>
    </div>

    <%# 感想カード: DrinkingLog 情報 %>
    <div class="bg-white rounded-2xl shadow-sm border border-herb-green-100 p-6 md:p-8">
      <div class="flex items-center gap-3 mb-6">
        <h2 class="text-xl font-bold text-herb-green-800">研究結果の感想</h2>
        <% if @recipe.drinking_log %>
          <div class="bg-yellow-100 text-yellow-700 px-3 py-1 rounded-full text-sm font-bold">
            ★ <%= @recipe.drinking_log.rating %> / 5
          </div>
        <% end %>
      </div>

      <% if @recipe.drinking_log %>
        <div class="space-y-6">
          <%# 味のパラメータ表示 %>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
            <% DrinkingLog::FLAVOR_MAPPING.each do |ja_name, column| %>
              <% value = @recipe.drinking_log.send(column).to_i %>
              <div class="flex flex-col items-center p-2 bg-gray-50 rounded-lg border border-gray-100">
                <div class="flex justify-between w-full px-1 mb-1">
                  <span class="text-[10px] text-gray-500"><%= ja_name %></span>
                  <span class="text-[10px] font-bold text-herb-green-600"><%= value %></span>
                </div>
                <div class="flex gap-0.5">
                  <% 5.times do |i| %>
                    <div class="w-2 h-3 rounded-sm <%= i < value ? 'bg-herb-green-600' : 'bg-gray-200' %>"></div>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>

          <%# 感想テキスト %>
          <div class="bg-herb-green-50/30 rounded-xl p-4 border border-herb-green-100">
            <p class="text-sm text-herb-green-900 whitespace-pre-wrap"><%= @recipe.drinking_log.impression %></p>
          </div>
        </div>
      <% else %>
        <div class="text-center py-8">
          <p class="text-sm text-gray-400 mb-4">まだ感想が記録されていません</p>
          <% if @recipe.user == current_user %>
            <%= link_to "感想を入力する", new_recipe_drinking_log_path(@recipe), 
                  class: "inline-block px-6 py-2 bg-herb-green-600 text-white text-sm font-medium rounded-xl hover:bg-herb-green-700 transition-colors shadow-sm" %>
          <% end %>
        </div>
      <% end %>
    </div>

    <%# 戻るリンク %>
    <div class="text-center">
      <%= link_to "← 一覧に戻る", home_path,
            class: "text-herb-green-500 text-sm hover:text-herb-green-700 transition-colors" %>
    </div>
  </div>

  <%= render 'shared/footer' %>
</div>
